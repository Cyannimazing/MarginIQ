{
  "expo": {
    "name": "MarginIQ",
    "slug": "marginiq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/ICON-MARGINIQ.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/ICON-MARGINIQ.png",
      "resizeMode": "contain",
      "backgroundColor": "#052e16"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/ICON-MARGINIQ.png",
        "backgroundColor": "#14532d",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.cyann1730.marginiq",
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "64a10b4a-7f81-4442-9079-986bc6fe4356"
      }
    }
  }
}
